{
  "name": "@ebs/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ebs/agent-core": "workspace:*",
    "@ebs/document-ir": "workspace:*",
    "@ebs/extraction-scorecard": "workspace:*",
    "@ebs/diff-engine": "workspace:*",
    "@ebs/ground-truth-schema": "workspace:*",
    "@ebs/job-runner": "workspace:*",
    "@ebs/parsing": "workspace:*",
    "@ebs/storage": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
